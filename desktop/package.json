{
    "name": "lmu-telemetry-lab",
    "version": "1.2.2",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.lmu.telemetry.lab",
        "productName": "LMU Telemetry Lab",
        "directories": {
            "output": "../dist-electron"
        },
        "icon": "build/icon.png",
        "extraResources": [
            {
                "from": "../dist/lmu-telemetry-backend",
                "to": "backend-dist/lmu-telemetry-backend",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": "nsis"
        }
    },
    "devDependencies": {
        "electron": "^31.0.0",
        "electron-builder": "^24.13.3"
    }
}